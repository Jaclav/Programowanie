   "source": [
    "def is_palindrome(S):\n",
    "    S=S.lower()\n",
    "    for i,s in enumerate(S[:len(S)//2]):\n",
    "        if s != s[-i]:\n",
    "            return False\n",
    "    return True\n",
    "\n",
    "is_palindrome(\"AnQna\")"
   ]
